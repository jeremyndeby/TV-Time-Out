{
  "manifest_version": 3,
  "name": "TV Time Out by Refract",
  "version": "1.2.0",
  "description": "Export your complete TV Time tracking data — shows, anime, movies, episodes and custom lists. Fast, 100% client-side, no server required. Built by the Refract team.",

  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "downloads"
  ],

  "host_permissions": [
    "https://app.tvtime.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "TV Time Out",
    "default_icon": {
      "16": "icons/logo.png",
      "48": "icons/logo.png",
      "128": "icons/logo.png"
    }
  },

  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  }
}
